<odoo>
<!--Search View-->
    <record id="todo_task_search_view" model="ir.ui.view">
        <field name="name">todo task search view</field>
        <field name="model">todo.task</field>
        <field name="arch" type="xml">
            <search>
                <field name="task_name"/>
                <field name="assign_to_id"/>

                <filter name="new_tasks_filter" string="New Tasks" domain="[('status', '=', 'new')]"/>
                <filter name="in_progress_tasks_filter" string="In Progress Tasks" domain="[('status', '=', 'in_progress')]"/>
                <filter name="completed_tasks_filter" string="Completed Tasks" domain="[('status', '=', 'completed')]"/>

                <filter name="group_assign_to" string="Assign To" context="{'group_by' : 'assign_to_id'}"/>
                <filter name="group_status" string="Status" context="{'group_by' : 'status'}"/>
                <filter name="group_due_date" string="Due Date" context="{'group_by' : 'due_date'}"/>

            </search>
        </field>
    </record>

<!--Form View-->
    <record id="todo_task_form_view" model="ir.ui.view">
        <field name="name">todo task form view</field>
        <field name="model">todo.task</field>
        <field name="arch" type="xml">
            <form delete="0">
                <sheet>
                    <header>
                        <button name="action_new" type="object" class="btn-primary" string="Set to New" invisible="status in ('new', 'in_progress', 'completed')"/>
                        <button name="action_in_progress" type="object" class="btn-secondary" string="In Progress" invisible="status in ('in_progress', 'completed', 'closed')"/>
                        <button name="action_completed" type="object" class="btn-success" string="Completed" invisible="status in ('new', 'completed', 'closed')"/>

                        <field name="status" widget="statusbar"/>
                    </header>
                    <div class = "oe_title">
                        <label for = "ref"/>
                        <h1>
                            <field name="ref"/>
                        </h1>

                        <label for = "task_name"/>
                        <h3>
                            <field name="task_name" groups="todo_management.managers_group"/>
                            <field name="task_name" readonly="1" groups="todo_management.users_group"/>
                        </h3>
                    </div>
<!--                Group of fields for Managers (not readonly)-->
                    <group groups="todo_management.managers_group">
                        <field name="assign_to_id"/>
                        <field name="description"/>
                        <field name="due_date" required="True" options="{'min_date': 'today'}"/>
                        <field name="active" invisible="status in ('new', 'in_progress')"/>
                        <field name="estimated_time"/>
                        <field name="total_timesheet_time"/>
                    </group>
<!--                Group of fields for Users not Managers (readonly)-->
                    <group groups="todo_management.users_group">
                        <field name="assign_to_id" readonly="1"/>
                        <field name="description" readonly="1"/>
                        <field name="due_date" required="True" options="{'min_date': 'today'}" readonly="1"/>
                        <field name="active" invisible="status in ('new', 'in_progress')" readonly="1"/>
                        <field name="estimated_time" readonly="1"/>
                        <field name="total_timesheet_time"/>
                    </group>
                    <notebook invisible="status in ('new', 'completed', 'closed')">
                        <page string="Timesheet">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="date" required="True" options="{'max_date': 'today'}"/>
                                    <field name="description"/>
                                    <field name="time"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </chatter>
            </form>
        </field>
    </record>

<!--List View-->
    <record id="todo_task_list_view" model="ir.ui.view">
        <field name="name">todo task list view</field>
        <field name="model">todo.task</field>
        <field name="arch" type="xml">
            <list class="header_style" decoration-danger="(is_late)">
                <header>
                    <button name="action_open_bulk_task_assignment_wizard" type="object" string="Assign To"/>
                </header>

                <field name="ref"/>
                <field name="task_name"/>
                <field name="assign_to_id"/>
                <field name="description"/>
                <field name="due_date"/>
                <field name="estimated_time"/>
                <field name="status"/>
                <field name="active"/>
                <field name="is_late"/>
            </list>
        </field>
    </record>

<!--window Action-->
    <record id="all_tasks_action" model="ir.actions.act_window">
        <field name="name">All Tasks</field>
        <field name="res_model">todo.task</field>
    </record>

<!--Server Action-->
    <record id="todo_task_close_server_action" model="ir.actions.server">
        <field name="name">Close</field>
        <field name="model_id" ref="model_todo_task"/>
        <field name="binding_model_id" ref="model_todo_task"/>
        <field name="state">code</field>
        <field name="code">action = records.server_action_closed()</field>
    </record>

<!--Automated Action (Cron Job)-->
    <record id="todo_task_check_due_date_cron_action" model="ir.cron">
        <field name="name">TodoTask: check due date</field>
        <field name="model_id" ref="model_todo_task"/>
        <field name="state">code</field>
        <field name="code">model.cron_action_check_due_date()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
    </record>

<!--dropdown list item-->
    <menuitem
            id="all_tasks_menu_item"
            name="All Tasks"
            parent="todo_root_menu"
            action="all_tasks_action"
    />
</odoo>