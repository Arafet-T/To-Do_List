<odoo>
<!--Wizard's form view-->
    <record id="bulk_task_assignment_wizard_form_view" model="ir.ui.view">
        <field name="name">bulk task assignment wizard form view</field>
        <field name="model">bulk.task.assignment</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="todo_task_ids" widget="many2many_tags" readonly="1"/>
                    <field name="assign_to_id"/>
                </group>
                <footer>
                    <button string="Confirm" type="object" name="action_wizard_confirm" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

<!--Wizard's Window Action-->
    <record id="bulk_task_assignment_wizard_action" model ="ir.actions.act_window">
        <field name="name">Tasks Assignment</field>
        <field name="res_model">bulk.task.assignment</field>
        <field name="target">new</field>
        <field name="view_mode">form</field>
    </record>
</odoo>